    "appwrite": "^24.1.1",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "groq-sdk": "^1.1.1",
    "hono": "^4.12.9",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
